 #ifndef __TrafficLightDebug__idl__
#define __TrafficLightDebug__idl__
#include "TrafficLightBox.idl"
module ros2_interface{
 module msg{
  struct TrafficLightDebug{
    ros2_interface::msg::TrafficLightBox   _cropbox;
    sequence<ros2_interface::msg::TrafficLightBox> _box;
    int32   _signal_num;
    int32   _valid_pos;
    double   _ts_diff_pos;
    double   _ts_diff_sys;
    int32   _project_error;
