    sequence<ros2_interface::msg::TrafficLightBox> _projected_roi;
    sequence<ros2_interface::msg::TrafficLightBox> _rectified_roi;
    sequence<ros2_interface::msg::TrafficLightBox> _debug_roi;
  };
 };
}; 
#endif