 #ifndef __ObstacleList__idl__
#define __ObstacleList__idl__
#include "Header.idl"
#include "Obstacle.idl"
module ros2_interface{
 module msg{
  struct ObstacleList{
    ros2_interface::msg::Header   _header;
    int32   _sensor_id;
    sequence<ros2_interface::msg::Obstacle> _obstacle;
    int32   _error_code;
    boolean   _is_valid;
    int32   _change_origin_flag;
  };
 };
}; 
#endif