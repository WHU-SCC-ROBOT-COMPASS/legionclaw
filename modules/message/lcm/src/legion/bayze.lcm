    int8_t utm_zone_char; // UTM区号
    Point3D attitude; // 三轴姿态
    Point3D linear_velocity; // 线速度信息
    Point3D sd_position; // 位置标准差
    Point3D sd_attitude; // 姿态标准差
    Point3D sd_velocity; // 速度标准差
    double cep68; // cep68数据位
    double cep95; // cep95数据位
    double second; // 时间
    int32_t sat_use_num; // 使用卫星数
    int32_t sat_in_view_num; // 可见卫星数
    int16_t solution_status; // 求解状态
    int16_t position_type; // 定位状态
    double p_dop; // pDop数据位
    double h_dop; // hDop数据位
    double v_dop; // vDop数据位
    Point3D attitude_dual; // 双天线姿态
    Point3D sd_angle_dual; // 双天线角度标准差
    double base_line_length_dual; // 双天线距离
    int32_t solution_status_dual; // 双天线求解状态
    int32_t position_type_dual; // 双天线定位状态
    int32_t solution_source_dual; // 双天线求解源
    int32_t aoc; // Aoc数据位
    int32_t rtk_baseline; // RTK基线信息
    Point3D angular_velocity; // 角速度信息
    Point3D acceleration; // 加速度信息
}

// ObuCmdMsg::ObuCmdMsg
struct ObuCmdMsg
{
    Header header; // timestamp is included in header
    int32_t id; // obu的id身份
    string name; // obu的名称
    int32_t obu_cmd_list_size;
    ObuCmd obu_cmd_list[obu_cmd_list_size]; // 命令列表
}

// RoutingRequest::RoutingRequest
struct RoutingRequest
{
    Header header; // timestamp is included in header
    string request_source; // 发起请求的来源名称
    int8_t request_type; // REQUEST_TYPE=0//无效 REQUEST_TYPE=1//正常路由 REQUEST_TYPE=2//泊车路由
    int16_t num_of_kp; // 关键点数量
    int32_t key_point_list_size;
    KeyPoint key_point_list[key_point_list_size]; // 关键点列表，第一个为起点，最后一个为终点，中间为途经点
}

// ObuCmd::ObuCmd
struct ObuCmd
{
    int32_t code; // 指令编码：10001、自动驾驶使能开关；
    int32_t val; // 编码值：0、不响应；1、自定义状态；2、自定义状态...（更多参考：“ObuCmdMsg.md”）
}

// ParkingInfo::ParkingInfo
struct ParkingInfo
{
    Header header; // timestamp is included in header
    int32_t parking_space_id; // 停车位id
    int32_t parking_type; // PARKING_TYPE=0//无效泊车 PARKING_TYPE=1//水平泊车 PARKING_TYPE=2//垂直泊车 PARKING_TYPE=3//倾斜泊车
    int32_t parking_status; // PARKING_ENABLE=0//可泊 PARKING_DISENABLE=1//不可泊 PARKING_NONOPTIONAL=2//不可选
    double confidence; // 车位置信度
    Point3D center_point_of_parking; // 世界坐标系下停车位中心点
    double theta; // 世界坐标系下的夹角（单位rad），车位出口与正东方向夹角
    double width; // 停车位宽（单位m）
    double length; // 停车位长单位m）
    double yaw_offset; // 停车位角度偏移量（倾斜车位），倾斜车位与道路边线夹角,(单位m）
    Polygon3D polygon; // 世界坐标系下的车位多边形
    int32_t sensor_id; // 车位数据来自相机id 0-front_center相机 1-front_left相机 2-front_right相机 3-left_front相机 4-left_back右后相机 5-right_front相机 6-right_back相机 7-back相机 8-相机融合
    boolean is_lane_width_valid; // 车道宽度是否有效
    double lane_width; // 泊车可用(双)车道宽度
    int32_t parking_stoppers_size;
    ParkingStopper parking_stoppers[parking_stoppers_size]; // 车位内部的限位器数组
    int32_t parking_direction_type; //   DIR_INVALID = 0,   LEFT = 1,   UP = 2,   RIGHT = 3,   DOWN = 4,
    int32_t left_occupied_status; // 0-unknown 未知，1-empty 空闲，2-occupied 被占用
    int32_t right_occupied_status; // 0-unknown 未知，1-empty 空闲，2-occupied 被占用
    int32_t parking_source_type; // 0-线车位， 1-空间车位， 2-融合车位
}

// KeyPoint::KeyPoint
struct KeyPoint
{
    int16_t id; // 关键点id
    double latitude; // 关键点纬度
    double longitude; // 关键点经度
    double ele; // 关键点海拔
    double heading; // 关键点航向角（与北方向夹角，顺时针方向为正，单位为°）
    string name; // 关键点名称
}

// SensorCalibrator::SensorCalibrator
struct SensorCalibrator
{
    Point3D pose; // 传感器安装位置(相对于后轴中心点)
    Point3D angle; // 传感器安装角度(车体坐标系)
}

// TrafficLight::TrafficLight
struct TrafficLight
{
    int32_t color; // UNKNOWN = 0; RED = 1; YELLOW = 2; GREEN = 3; BLACK = 4;
    int32_t id; // light id
    int32_t type; // STRAIGHT = 0; TURN_LEFT = 1; TURN_RIGHT = 2; STRAIGHT_TURN_LEFT = 3; STRAIGHT_TURN_RIGHT =4; CIRCULAR = 5; PEDESTRIAN = 6; CYCLIST = 7; UNKNOWN = 8;
    double confidence; // 置信度confdence: [0-1]
    ImageRect light_rect; // 交通灯矩形框light rect
    Point3D position; // 交通灯位置position of light
    double distance; // 距离distance between light and stop line
    int32_t light_lanes_size;
    int32_t light_lanes[light_lanes_size]; // corresponding lanes of light
    double tracking_time; // duration of a light since track
    boolean blink; // true:
    double blinking_time; // duration of a light blinking
    double remaining_time; // V2X time of light
    Time create_time; // time of light detected
}

// StopPoint::StopPoint
struct StopPoint
{
    Point3D point; // 点xyz
    double theta; // 方向（与东方向夹角，逆时针方向为正，单位为弧度）
    int8_t type; // STOP_TYPE_TERMINAL=0 //目的地终点 STOP_TYPE_JUNCTION=1 //路口停止线
    double stop_distance; // 距停止点多少米停车
}

// LanePoint::LanePoint
struct LanePoint
{
    Point3D point; // 点xyz
    double theta; // 方向（与东方向夹角，逆时针方向为正，单位为弧度）
    double mileage; // 总体里程
    double limit_speed; // 地图限速（单位m/s）
    double left_road_width; // 左边车道宽
    double right_road_width; // 右边车道宽
    int32_t left_line_type; // 左边车线线型
    int32_t right_line_type; // 右边车线线型
}

// LaneInfo::LaneInfo
struct LaneInfo
{
    int8_t priority; // 道路优先级：0（非推荐车道）1（推荐车道）
    int8_t global_id; // 道路全局id（从左至右，从0开始）
    int8_t predecessor_id; // 上一车道id
    int8_t successor_id; // 下一车道id
    int8_t left_neighbor_id; // 左边相邻车道id
    int8_t right_neighbor_id; // 右边相邻车道id
    int8_t type; // 0：未知 1：左转道不可掉头 2：直行道 3：右转道 4：直行且可左转道 5：直行且可右转道 6：左转道且可掉头 7：不可左转仅可掉头
    int32_t lane_points_size;
    LanePoint lane_points[lane_points_size]; // 道路参考线（z）
}

// ObstacleIntent::ObstacleIntent
struct ObstacleIntent
{
    int32_t type; // 估计障碍物的意图        0-UNKNOWN, 1-STOP, 2-STATIONARY, 3-移动 MOVING, 4-HANGE_LANE, 5-LOW_ACCELERATION, 6-HIGH_ACCELERATION, 7-LOW_DECELERATION, 8-HIGH_DECELERATION, 
}

// RoutingResponse::RoutingResponse
struct RoutingResponse
{
    Header header; // timestamp is included in header
    int32_t plan_status; // 规划结果状态
    int32_t replan_flag; // REPLAN_FLAG_NONE=0  //不需要重规划 REPLAN_FLAG_NAVI=1 //网络层重规划 REPLAN_FLAG_HUMAN=2 //人为重规划
    int32_t route_reason; // 规划原因 ROUTE_REASON_HMI = 0 //hmi上触发规划 ROUTE_REASON_PLATOON_HEADER = 1 //车队头车下发规划 ROUTE_REASON_PLATOON_OTHER = 2 //车队其他车辆下发规划
    int32_t lane_list_size;
    LaneInfo lane_list[lane_list_size]; // 分段路径规划结果
}

// StopInfo::StopInfo
struct StopInfo
{
    Header header; // timestamp is included in header
    int32_t stop_points_size;
    StopPoint stop_points[stop_points_size]; // 停车点列表
}

// ADCTrajectory::ADCTrajectory
struct ADCTrajectory
{
    Header header; // timestamp is included in header
    double total_path_length; // unit meters(m)
    double total_path_time; // unit seconds(s)
    int32_t trajectory_points_size;
    TrajectoryPoint trajectory_points[trajectory_points_size]; // 规划轨迹点列
    int32_t car_action; // 车辆行为： CAR_ACTION_NONE=0  //无效值 CAR_ACTION_SINGLE=1 //单车 CAR_ACTION_PLATOON_HEAD=2 //车队头车 CAR_ACTION_PLATOON_OTHER=3 //车队其他车辆
    int32_t behaviour_lat_state; // 自动驾驶状态（主要指横向状态）
    int32_t behaviour_lon_state; // 自动驾驶状态（主要指纵向状态）
    int32_t scenario; // 驾驶场景 0-UNKNOWN, 1-CRUISE, 2-CRUISE_URBAN 3-CRUISE_HIGHWAY, 2000-JUNCTION  2001-JUNCTION_TRAFFIC_LIGHT 2002-JUNCTION_STOP_SIGN
    int32_t driving_mode; // 驾驶模式： 1：人工驾驶， 2：辅助驾驶， 3：自动驾驶
    int32_t adc_trajectory_type; // 轨迹类型： TRAJECTORY_TYPE_ABSOLUTE=0 //绝对规划轨迹 TRAJECTORY_TYPE_RELATIVE=1 //相对规划轨迹 TRAJECTORY_TYPE_INVALID=2 //无效规划轨迹
    EStop estop; // emergency stop
    boolean is_replan; // is_replan == truemean replan triggered(default = false)
    string replan_reason; //  
    int32_t right_of_way_status; // UNPROTECTED = 0;PROTECTED = 1;
    RSSInfo rss_info; // output related to RSS
}

// BBox2D::BBox2D
struct BBox2D
{
    int16_t xmin; // 图像框左上角的x坐标
    int16_t ymin; // 图像框左上角的y坐标
    int16_t xmax; // 图像框右下角的x坐标
    int16_t ymax; // 图像框右下角的y坐标
}

// Obstacle::Obstacle
struct Obstacle
{
    Time timestamp; // 时间戳
    int32_t id; // 障碍物id
    double existence_prob; // 障碍物存在的概率
    Time create_time; // 障碍物被识别的时间戳
    Time last_updated_time; // 障碍物上一次更新的时间
    Point3D center_pos_vehicle; // 车辆坐标系下障碍物的中心位置
    Point3D center_pos_abs; // 世界坐标系下障碍物的中心位置
    double theta_vehicle; // 车辆坐标系下障碍物的朝向
    double theta_abs; // 世界坐标系下障碍物的朝向
    Point3D velocity_vehicle; // 车辆坐标系下障碍物的速度
    Point3D velocity_abs; // 世界坐标系下障碍物的速度
    double length; // 障碍物长度
    double width; // 障碍物宽度
    double height; // 障碍物高度
    int32_t image_key_points_size;
    ImageKeyPoint image_key_points[image_key_points_size]; // 图像坐标系下障碍物多边形
    int32_t polygon_point_abs_size;
    Point3D polygon_point_abs[polygon_point_abs_size]; // 世界坐标系下障碍物多边形
    int32_t polygon_point_vehicle_size;
    Point3D polygon_point_vehicle[polygon_point_vehicle_size]; // 车辆坐标系下障碍物多边形
    double tracking_time; // 障碍物被追踪的时间
    int32_t type; // 障碍物类别： UNKNOWN = 0; UNKNOWN_MOVABLE = 1; UNKNOWN_UNMOVABLE = 2; PEDESTRIAN = 3; BICYCLE = 4; VEHICLE = 5;
    double confidence; // 障碍物类别置信度
    int32_t confidence_type; // 障碍物置信度类别： CONFIDENCE_UNKNOWN = 0; CONFIDENCE_CNN = 1; CONFIDENCE_RADAR = 2;
    int32_t drops_size;
    Point3D drops[drops_size]; // 障碍物轨迹点
    Point3D acceleration_vehicle; // 车辆坐标系下障碍物的加速度
    Point3D acceleration_abs; // 世界坐标系下障碍物的加速度
    Point2D anchor_point_image; // 障碍物尾框中心点(图像坐标系)
    Point3D anchor_point_vehicle; // 障碍物尾框中心点(车辆坐标系)
    Point3D anchor_point_abs; // 障碍物尾框中心点(世界坐标系)
    BBox2D bbox2d; // 障碍物图像框
    BBox2D bbox2d_rear; // 障碍物图像尾框
    int32_t sub_type; // 障碍物类别： ST_UNKNOWN = 0; ST_UNKNOWN_MOVABLE = 1; ST_UNKNOWN_UNMOVABLE = 2; ST_CAR = 3; ST_VAN = 4; ST_TRUCK = 5; ST_BUS = 6; ST_CYCLIST = 7; ST_MOTORCYCLIST = 8; ST_TRICYCLIST = 9; ST_PEDESTRIAN = 10; ST_TRAFFICCONE = 11; ST_PILLAR = 12; ST_SPEED_BUMP = 13;
    double height_above_ground; // 障碍物近地点到地面的高度
    int32_t position_abs_covariance_size;
    double position_abs_covariance[position_abs_covariance_size]; // 世界坐标系下障碍物中心位置的协方差矩阵
    int32_t velocity_abs_covariance_size;
    double velocity_abs_covariance[velocity_abs_covariance_size]; // 世界坐标系下障碍物速度的协方差矩阵
    int32_t acceleration_abs_covariance_size;
    double acceleration_abs_covariance[acceleration_abs_covariance_size]; // 世界坐标系下障碍物加速度的协方差矩阵
    double theta_abs_covariance; // 世界坐标系下障碍物朝向的协方差矩阵
    int32_t position_vehicle_covariance_size;
    double position_vehicle_covariance[position_vehicle_covariance_size]; // 车辆坐标系下障碍物中心位置的协方差矩阵
    int32_t velocity_vehicle_covariance_size;
    double velocity_vehicle_covariance[velocity_vehicle_covariance_size]; // 车辆坐标系下障碍物速度的协方差矩阵
    int32_t acceleration_vehicle_covariance_size;
    double acceleration_vehicle_covariance[acceleration_vehicle_covariance_size]; // 车辆坐标系下障碍物加速度的协方差矩阵
    double theta_vehicle_covariance; // 车辆坐标系下障碍物朝向的协方差矩阵
    SensorCalibrator sensor_calibrator; // 传感器标定参数
    int8_t cipv_flag; // 障碍物状态标志（0-CIPV 1-CIPS 2-LPIHP 3-RPIHP 4-NONE）
    int32_t lane_position; // 车道线位置 -2-NEXT_LEFT_LANE -1-LEFT_LANE 0-EGO_LANE 1-RIGHT_LANE 2-NEXT_RIGHT_LANE 3-OTHERS 4-UNKNOWN
    double pihp_percentage; // 临车道车辆压线比例
    int32_t blinker_flag; // 障碍物车辆信号灯状态： 0-OFF 1-LEFT_TURN_VISIBLE 2-LEFT_TURN_ON 3-RIGHT_TURN_VISIBLE 4-RIGHT_TURN_ON 5-BRAKE_VISIBLE 6-BRAKE_ON 7-UNKNOWN
    int32_t fusion_type; // 融合障碍物类型 0-CAMERA 1-RADAR 2-LIDAR 3-ULTRASONIC 4-FUSED 5-UNKNOWN
}

// RSSInfo::RSSInfo
struct RSSInfo
{
    boolean is_rss_safe; //  
    double cur_dist_lon; // current longitudinal distance
    double rss_safe_dist_lon; // longitudinal safe distance of rss
    double acc_lon_range_minimum; // Minimum range of longitudinal acceleration
    double acc_lon_range_maximum; // Maximum range of longitudinal acceleration
    double acc_lat_left_range_minimum; // Minimum left range of lateral acceleration
    double acc_lat_left_range_maximum; // Maximum left range of lateral acceleration
    double acc_lat_right_range_minimum; // Minimum right range of lateral acceleration
    double acc_lat_right_range_maximum; // Maximum right range of lateral acceleration
}

// ObstaclePriority::ObstaclePriority
struct ObstaclePriority
{
    int32_t priority; // CAUTION = 1; NORMAL = 2; IGNORE = 3;
}

// PlanningCmd::PlanningCmd
struct PlanningCmd
{
    Header header; //  
    int32_t turn_lamp_ctrl; // 转向灯 TURN_INACTIVE_SIGNAL:0 TURN_LEFT_SIGNAL:1 TURN_RIGHT_SIGNAL:2 TURN_INVALID_SIGNAL:3
    int32_t high_beam_ctrl; // 0 关闭 1 开启 2 不响应
    int32_t low_beam_ctrl; // 0 关闭 1 开启 2 不响应
    int32_t horn_ctrl; // 0 关闭 1 开启 2 不响应
    int32_t front_wiper_ctrl; // 前雨刮器 0 关闭 1 开启
    int32_t rear_wiper_ctrl; // 后雨刮器 0 关闭 1 开启
    int32_t position_lamp_ctrl; // 位置灯 0 关闭 1 开启
    int32_t front_fog_lamp_ctrl; // 前雾灯 0 关闭 1 开启
    int32_t rear_fog_lamp_ctrl; // 后雾灯 0 关闭 1 开启
    int32_t brake_lamp_ctrl; // 刹车灯 一般情况自动控制 0 关闭 1 开启
    int32_t alarm_lamp_ctrl; // 警报灯 双闪 0 关闭 1 开启
    int32_t lf_door_ctrl; // 左前门控制 0 关闭 1 开启
    int32_t rf_door_ctrl; // 右前门控制 0 关闭 1 开启
    int32_t lr_door_ctrl; // 左后门控制 0 关闭 1 开启
    int32_t rr_door_ctrl; // 右后门控制 0 关闭 1 开启
}

// PredictionObstacle::PredictionObstacle
struct PredictionObstacle
{
    PerceptionObstacle perception_obstacle; // perception info of obstacle
    double timestamp; // GPS time in seconds
    double predicted_period; // the length of the time for this prediction (e.g. 10s)
    int32_t trajectory_size;
    TrajectoryInPrediction trajectory[trajectory_size]; // can have multiple trajectories per obstacle
    ObstacleIntent intent; // 估计障碍物的意图        0-UNKNOWN, 1-STOP, 2-STATIONARY, 3-移动 MOVING, 4-HANGE_LANE, 5-LOW_ACCELERATION, 6-HIGH_ACCELERATION, 7-LOW_DECELERATION, 8-HIGH_DECELERATION, 
    ObstaclePriority priority; // 障碍物优先级               1-CAUTION, 2-NORMAL, 3-IGNORE
    ObstacleInteractiveTag interactive_tag; //  
    boolean is_static; // is obstacle static (default = false)
}

// TrajectoryInPrediction::TrajectoryInPrediction
struct TrajectoryInPrediction
{
    double probability; // probability of this trajectory
    int32_t trajectory_points_size;
    TrajectoryPoint trajectory_points[trajectory_points_size]; //  
}

// TrajectoryPointInPrediction::TrajectoryPointInPrediction
struct TrajectoryPointInPrediction
{
    PathPoint path_point; // path point
    double v; // linear velocity
    double a; // linear acceleration
    double relative_time; // relative time from beginning of the trajectory
}

// PredictionTrajectoryPoint::PredictionTrajectoryPoint
struct PredictionTrajectoryPoint
{
    Point3D predition_path_point; //  
    double timestamp; //  
}

// PerceptionObstacle::PerceptionObstacle
struct PerceptionObstacle
{
    int32_t id; //  
    Point3D position; //  
    double theta; //  
    Point3D velocity; //  
    double length; //  
    double width; //  
    double height; //  
    int32_t polygon_point_size;
    Point3D polygon_point[polygon_point_size]; //  
    double tracking_time; //  
    int32_t type; // 障碍物类型： 0-Unknown 1-Unknown_movable 2-Unknown_unmovable 3-Pedestrian 4-Bicycle   5-Vehicle
    int32_t lane_position; // 车道线位置 -2-NEXT_LEFT_LANE -1-LEFT_LANE 0-EGO_LANE 1-RIGHT_LANE 2-NEXT_RIGHT_LANE 3-OTHERS 4-UNKNOWN
    double confidence; //  
    double timestamp; //  
    int8_t confidence_type; // 置信度类型                  0-CONFIDENCE_UNKNOWN, 1-CONFIDENCE_CN, 2-CONFIDENCE_RAD
    Point3D drops; //  
    Point3D acceleration; //  
    Point3D anchor_point; //  
    int32_t bounding_box_size;
    Point3D bounding_box[bounding_box_size]; //  
    int32_t sub_type; //  
    double height_above_ground; //  
    int32_t position_covariance_size;
    double position_covariance[position_covariance_size]; //  
    int32_t velocity_covariance_size;
    double velocity_covariance[velocity_covariance_size]; //  
    int32_t acceleration_covariance_size;
    double acceleration_covariance[acceleration_covariance_size]; //  
    int8_t light_status; //  
}

// ObstacleFeature::ObstacleFeature
struct ObstacleFeature
{
    int32_t obstacle_id; // Obstacle ID
    Point3D polygon_point; // 障碍物边框点列
    Point3D position; //  
    Point3D front_position; //  
    Point3D velocity; //  
    Point3D raw_velocity; // from perception
    Point3D acceleration; //  
    double velocity_heading; //  
    double speed; //  
    double acc; //  
    double theta; //  
    double length; //  
    double width; //  
    double height; //  
    double tracking_time; //  
    double timestamp; //  
    Point3D t_position; //  
    Point3D t_velocity; // [deprecated = true]
    double t_velocity_heading; // [deprecated = true]
    double t_speed; // [deprecated = true]
    Point3D t_acceleration; // [deprecated = true]
    double t_acc; // [deprecated = true]
    boolean is_still; // [deprecated = false]
    int32_t type; // 感知到的障碍物类型         0-UNKNOWN, 1-UNKNOWN_MOVABLE, 2-UNKNOWN_UNMOVABLE, 3-PEDESTRIAN, 4-BICYCLE,     5-VEHICLE
    double label_update_time_delta; //  
    ObstaclePriority priority; // CAUTION = 1; NORMAL = 2; IGNORE = 3;
    boolean is_near_junction; //  
    int32_t future_trajectory_points_size;
    PredictionTrajectoryPoint future_trajectory_points[future_trajectory_points_size]; // Obstacle ground-truth labels:
    int32_t short_term_predicted_trajectory_points_size;
    TrajectoryPointInPrediction short_term_predicted_trajectory_points[short_term_predicted_trajectory_points_size]; // Obstacle short-term predicted trajectory points
    int32_t predicted_trajectory_size;
    TrajectoryInPrediction predicted_trajectory[predicted_trajectory_size]; // Obstacle predicted trajectories
    int32_t adc_trajectory_point_size;
    TrajectoryPointInPrediction adc_trajectory_point[adc_trajectory_point_size]; // ADC trajectory at the same frame
}

// LaneLine::LaneLine
struct LaneLine
{
    int32_t lane_type; //  车道线类型：   SOLID = 0;   DASHED = 1;   ROAD_DELIMITER = 2;   NONE = 3;   UNKNOWN = 4;
    int32_t lane_color; //  车道线颜色：   WHITE = 0;   YELLOW = 1;   OTHERS = 2;   UNKNOWN = 3;
    int32_t pos_type; // 车道线位置类别：    BOLLARD_LEFT = -5;   FOURTH_LEFT = -4;   THIRD_LEFT = -3;   ADJACENT_LEFT = -2;  //!< lane marking on the left side next to ego lane   EGO_LEFT = -1;       //!< left lane marking of the ego lane   EGO_RIGHT = 1;       //!< right lane marking of the ego lane   ADJACENT_RIGHT = 2;  //!< lane marking on the right side next to ego lane   THIRD_RIGHT = 3;   FOURTH_RIGHT = 4;   BOLLARD_RIGHT = 5;   OTHER = 6;    //!< other types of lane   UNKNOWN = 7;  //!< background
    LaneLineCubicCurve curve_vehicle; // 车辆坐标系车道线三次曲线系数
    LaneLineCubicCurve curve_image; // 图像坐标系车道线三次曲线系数
    LaneLineCubicCurve curve_abs; // 世界坐标系车道线三次曲线系数
    int32_t pts_vehicle_size;
    Point3D pts_vehicle[pts_vehicle_size]; // 车辆坐标系车道线点集
    int32_t pts_image_size;
    Point2D pts_image[pts_image_size]; // 图像坐标系车道线点集
    int32_t pts_abs_size;
    Point3D pts_abs[pts_abs_size]; // 世界坐标系车道线点集
    EndPoints image_end_point; // 车道线上顶点与下顶点
    int32_t pts_key_size;
    Point2D pts_key[pts_key_size]; // 车道线关键点数组
    int8_t hd_lane_id; // 高精车道线id
    double confidence; // 车道线置信度
    int32_t lane_quality; //   车道线质量：   VERY_LOW = 0;   LOW = 1;   HIGH = 2;   VERY_HIGH = 3;
    int32_t fused_lane_type; //   融合车道线类别：   CAMERA = 0;   HD = 1;   FUSED = 2;   UNKNOWN = 3;   if value is 1, lane_quality = 3
    int32_t homography_mat_size;
    double homography_mat[homography_mat_size]; // 透视变换矩阵
    int32_t homography_mat_inv_size;
    double homography_mat_inv[homography_mat_inv_size]; // 透视变换逆矩阵
    int32_t lane_coordinate_type; //   坐标系类别：   FRAME = 0;   IMAGE = 1;   CAMERA = 2;   VEHICLE = 3;   ABSOLUTE = 4;
    int32_t use_type; //   使用类别：   REAL = 0;   VIRTUAL = 1;
    Time create_time; // 车道线被识别的时间戳
}

// LaneLineCubicCurve::LaneLineCubicCurve
struct LaneLineCubicCurve
{
    double start_x; // 车道线起始位置
    double end_x; // 车道线结束位置
    double a; // 三次曲线系数
    double b; //  
    double c; //  
    double d; //  
}

// EndPoints::EndPoints
struct EndPoints
{
    Point2D start; // 车道线上顶点
    Point2D end; // 车道线下顶点
}

// FreeSpace::FreeSpace
struct FreeSpace
{
    Header header; // timestamp is included in header
    int32_t sensor_id; // 安装的传感器id(camera,lidar,radar) ' 相机id: 0-front_center相机 1-front_left相机 2-front_right相机 3-left_front相机 4-left_back右后相机 5-right_front相机 6-right_back相机 7-back相机'  8-相机融合
    int32_t freespace_region_size;
    Polygon2D freespace_region[freespace_region_size]; // freespace轮廓图像坐标
    int32_t error_code; // 错误码（default = OK）
    boolean is_valid; // 障碍物数据是否合法
}

// HolisticPathPrediction::HolisticPathPrediction
struct HolisticPathPrediction
{
    LaneLineCubicCurve hpp; // 行驶路径预测： 1、针对没有车道线等特殊路段如：收费站附近、进出匝道附近、 维修区域附近，可以虚拟出可行驶路径预测； 2、针对车辆遮挡的区域，可以虚拟出可行驶路径预测；
    int32_t planning_source; // 规划路径来源:  0 - invalid,  1 - 双侧车道线,  2 - 左侧车道线,  3 - 右侧车道线, 4 - 左侧路沿，  5 - 右侧路沿， 6 - 前车轨迹，  7 - freespace, 8 - 本车轨迹预测
    double ego_lane_width; // 自车道宽度
    double confidence; // 置信度[0 - 1]
}

// RoadMark::RoadMark
struct RoadMark
{
    double longitude_dist; // 相对于车身坐标系原点的纵向距离,单位m
    double lateral_dist; // 相对于车身坐标系原点的横向距离,单位m
    double x; // 质心坐标x
    double y; // 质心坐标y
    double z; // 质心坐标z
    double confidence; // 置信度[0 - 1]
    int32_t type; // 标识类型 1 - 停止线 2 - 斑马线 3 - 禁停区 4 - 直行箭头 5 - 左转箭头 6 - 右转箭头 7 - 直行+左转 8 - 直行+右转 9 - 直行+左转+右转 10 - 掉头 11 - 左掉头 12 - 菱形(前方有人行横道) 13 - 倒三角 (减速让行) 14 - 地面文字
}

// TrafficLightDebug::TrafficLightDebug
struct TrafficLightDebug
{
    TrafficLightBox cropbox; //  
    int32_t box_size;
    TrafficLightBox box[box_size]; //  
    int32_t signal_num; //  
    int32_t valid_pos; //  
    double ts_diff_pos; //  
    double ts_diff_sys; //  
    int32_t project_error; //  
    double distance_to_stop_line; //  
    int32_t camera_id; //  
    int32_t crop_roi_size;
    TrafficLightBox crop_roi[crop_roi_size]; //  
    int32_t projected_roi_size;
    TrafficLightBox projected_roi[projected_roi_size]; //  
    int32_t rectified_roi_size;
    TrafficLightBox rectified_roi[rectified_roi_size]; //  
    int32_t debug_roi_size;
    TrafficLightBox debug_roi[debug_roi_size]; //  
}

// TrafficLightBox::TrafficLightBox
struct TrafficLightBox
{
    int32_t x; // 交通灯目标在图像上中心点横向方向像素位置
    int32_t y; // 交通灯目标在图像上中心点纵向方向像素位置
    int32_t width; // 交通灯目标在图像上宽度
    int32_t height; // 交通灯目标在图像上高度
    int32_t color; // UNKNOWN = 0; RED = 1; YELLOW = 2; GREEN = 3; BLACK = 4;
    boolean selected; // 是否选择
    string camera_name; // 相机名称
}

