    Header header; // timestamp is included in header
    int32_t uss_parking_type; // 超声波车位类型： 0-右侧平行 1-左侧平行 2-右侧垂直 3-左侧垂直
    Point3D parking_point0; // 车体中心坐标系下，超声波车位0点位置
    Point3D parking_point1; // 车体中心坐标系下，超声波车位1点位置
    Point3D parking_point2; // 车体中心坐标系下，超声波车位2点位置
    Point3D parking_point3; // 车体中心坐标系下，超声波车位3点位置
}

// CameraParkingStopper::CameraParkingStopper
struct CameraParkingStopper
{
    Header header; // timestamp is  included in header
    BBox2D bbox2d; // 限位器图像框
}

// ParkingStopper::ParkingStopper
struct ParkingStopper
{
    Header header; // timestamp is  included in header
    Point3D center_point_vehicle; // 车辆坐标系下限位器中心点坐标
    Point3D center_point_abs; // 绝对坐标系下限位器中心点坐标
    int32_t stopper_points_vehicle_size;
    Point3D stopper_points_vehicle[stopper_points_vehicle_size]; // 车辆坐标系下限位器关键点
    int32_t stopper_points_abs_size;
    Point3D stopper_points_abs[stopper_points_abs_size]; // 绝对坐标系下限位器关键点
}

// DiagnosticArray::DiagnosticArray
struct DiagnosticArray
{
    Header header; // timestamp is  included in header
    int32_t status_size;
    DiagnosticStatus status[status_size]; // 诊断状态
}

// DiagnosticStatus::DiagnosticStatus
struct DiagnosticStatus
{
    Header header; // timestamp is  included in header
    int32_t id; // level*100000 + 序号（RECOVER 400000） WARN 车运动状态（静止）100001 左前门状态（关闭）100002 右前门状态（关闭）100003 左后门状态（关闭）100004 右后门状态（关闭）100005 安全带状态（关闭）100006 后视镜状态（打开）100007 充电枪状态 100008 油门状态 （正常）100009 智驾系统（正常）100010 动力系统（正常）100011 左前轮胎压（正常）100012 右前轮胎压（正常）100013 左后轮胎压（正常）100014 右后轮胎压（正常）100015 转向系统（正常）100016 制动系统（正常）100017 档位系统（正常）100018 EPB系统（正常）100019 气囊状态（正常）100020 油箱盖状态（正常）100021 后备箱状态（正常）100022 底盘信息（正常）100023 定位信息（正常）100024 方向盘人工接管 100025 电量表（正常）100026 暂停超时 100027 暂停次数过多 100028 泊车超时 100029 人为刹车 100030 人为挂P挡 100031 障碍物碰撞 100032 EPB状态(释放) 100033 ERROR 规划失败 200000
    int32_t level; // 诊断状态
    string name; // 测试/组件报告的描述
    string message; // 状态描述
    string hardware_id; // 硬件的唯一描述
    int32_t values_size;
    KeyValues values[values_size]; // 与状态关联的key-value组
}

// KeyValues::KeyValues
struct KeyValues
{
    string key; //  
    string value; //  
}

// AlarmMessage::AlarmMessage
struct AlarmMessage
{
    Header header; // 消息头
    string alarm_proc; // 产生告警的进程名
    int32_t alarm_level; // 告警等级
    int32_t alarm_type; // 告警类型
    int32_t alarm_id; // 告警序列号，用于恢复告警
    int32_t alarm_display; // 告警展示类型
    string alarm_data; // 告警正文
}

// LaneletInfo::LaneletInfo
struct LaneletInfo
{
    int32_t lanelet_id; // 道路id，与地图文件对应
    double length; // 道路长度
}

// GlobalRouteMsg::GlobalRouteMsg
struct GlobalRouteMsg
{
    Header header; // 消息头
    int32_t route_size;
    LaneletInfo route[route_size]; // 一次导航的全程道路集合，从起点到终点排序
    LaneletInfo current_lanelet; // 当前所在车道的信息
    double total_mileage; // 总里程
    double cur_mileage; // 当前里程
    int32_t cur_slice_size;
    LaneletInfo cur_slice[cur_slice_size]; // 当前地图切片,用来绘制局部地图
}

// RouteFusionInfo::RouteFusionInfo
struct RouteFusionInfo
{
    int32_t fusion_flag; // 是否有效标志位
    string fusion_reason; // 融合原因
}

// RoadMarkList::RoadMarkList
struct RoadMarkList
{
    Header header; // timestamp is included in header
    int32_t roadmarks_size;
    RoadMark roadmarks[roadmarks_size]; // 交通标识列表
}

// HMIObuCmd::HMIObuCmd
struct HMIObuCmd
{
    int32_t code; // 指令编码：10001、自动驾驶使能开关；
    int32_t val; // 编码值：0、不响应；1、自定义状态；2、自定义状态...（更多参考：“ObuCmdMsg.md”）
}

// HMIObuCmdMsg::HMIObuCmdMsg
struct HMIObuCmdMsg
{
    Header header; // timestamp is included in header
    int32_t id; // obu的id身份
    string name; // obu的名称
    int32_t obu_cmd_list_size;
    HMIObuCmd obu_cmd_list[obu_cmd_list_size]; // 命令列表
}

// HMIParkingStateDisplay::HMIParkingStateDisplay
struct HMIParkingStateDisplay
{
    Header header; //  
    int32_t parking_type; // 0：无效 1：垂直泊车 2：水平泊车 3：斜方泊车
    int32_t moves_counter; // 揉库次数
    double remian_distance; // 剩余距离
    int32_t display_info; // 详细信息
    double distance_to_leader_obj; // 距离最近障碍物距离
    int32_t state; //  
}

// HMIParkingInfo::HMIParkingInfo
struct HMIParkingInfo
{
    Header header; // timestamp is  included in header
    int32_t parking_space_id; // // 停车位id
    int32_t parking_type; // // PARKING_TYPE=0 //无效泊车 PARKING_TYPE=1 //水平泊车 PARKING_TYPE=2 //垂直泊车 PARKING_TYPE=3 //倾斜泊车
    int32_t parking_status; // PARKING_ENABLE=0//可泊 PARKING_DISENABLE=1//不可泊 PARKING_NONOPTIONAL=2//不可选
    Point3D center_point_of_parking; // // 世界坐标系下停车位中心点
    double theta; // // 世界坐标系下的夹角（单位rad），车位出口与正东方向夹角
    double width; // // 停车位宽（单位m）
    double length; // // 停车位长单位m）
    boolean is_custom_parking; // // 是否是自定义车位
    Polygon3D polygon; // 世界坐标系下的车位多边形
    int32_t parking_source_type; // 0-线车位， 1-空间车位， 2-融合车位
}

// HMIParkingInfoList::HMIParkingInfoList
struct HMIParkingInfoList
{
    Header header; // timestamp is  included in header
    int32_t parking_info_size;
    HMIParkingInfo parking_info[parking_info_size]; //  
    boolean parking_out_enable; //  
    int32_t parking_out_direction; //  
    int32_t parking_out_id; //  
}

// HMIVehicleMsg::HMIVehicleMsg
struct HMIVehicleMsg
{
    Header header; //  
    int32_t driving_mode; // 驾驶状态
    int32_t gear_location; // 档位值
    double steering_value; // 方向盘转角
    double accel_value; // 线控驱动值（油门值）
    double brake_value; // 线控制动值（刹车值）
    double speed_mps; // 车速（m/s）
    PointLLH position; // 经纬度高程
    PointENU utm_position; // 相对参考点xyz坐标
    double pitch; // 方向(单位弧度，-π～π,正东:0, 逆时针。都满足右手定则)
    double roll; //  
    double heading; //  
    int32_t rtk_flag; // RTK标志值
    double origin_lat; // // 参考点纬度 GCJ-02格式
    double origin_lon; // // 参考点经度 GCJ-02格式
    double current_ins_yaw; //  
    int32_t auto_safe; // //  安全驾驶0:正常 1:左前车门没关 2:右前车门没关 3:左后车门没关 4:右后车门没关 5:未系安全带 6: 未打开反观镜 7:车辆未静止
    double battery_power_percentage; // 电池电量值
    int32_t charging_gun_status; // 充电枪状态
    int32_t chassis_error_code_size;
    int32_t chassis_error_code[chassis_error_code_size]; // 底盘错误码
    int32_t brake_lamp_status; // 刹车灯状态
    int32_t turn_lamp_status; // 转向灯状态
    PointENU mercator_position; // 转坐标系后的参考点
}

// HMIObstacle::HMIObstacle
struct HMIObstacle
{
    int32_t id; // 障碍物id
    Point3D center_pos_vehicle; // 车辆坐标系下障碍物的中心位置
    Point3D center_pos_abs; // 世界坐标系下障碍物的中心位置
    double theta_vehicle; // 车辆坐标系下障碍物的朝向
    double theta_abs; // 世界坐标系下障碍物的朝向
    double length; // 障碍物长度
    double width; // 障碍物宽度
    double height; // 障碍物高度
    int32_t type; // 障碍物类别： UNKNOWN = 0; UNKNOWN_MOVABLE = 1; UNKNOWN_UNMOVABLE = 2; PEDESTRIAN = 3; BICYCLE = 4; VEHICLE = 5;
    double confidence; // 障碍物类别置信度
    int32_t confidence_type; // 障碍物置信度类别： CONFIDENCE_UNKNOWN = 0; CONFIDENCE_CNN = 1; CONFIDENCE_RADAR = 2;
    int32_t sub_type; // 障碍物类别： ST_UNKNOWN = 0; ST_UNKNOWN_MOVABLE = 1; ST_UNKNOWN_UNMOVABLE = 2; ST_CAR = 3; ST_VAN = 4; ST_TRUCK = 5; ST_BUS = 6; ST_CYCLIST = 7; ST_MOTORCYCLIST = 8; ST_TRICYCLIST = 9; ST_PEDESTRIAN = 10; ST_TRAFFICCONE = 11; ST_PILLAR = 12; ST_SPEED_BUMP = 13;
    int32_t points_size;
    Point3D points[points_size]; //  
    int8_t cipv_flag; // 障碍物状态标志（0-CIPV 1-CIPS 2-LPIHP 3-RPIHP 4-NONE）
    int32_t fusion_type; //  
}

// HMIObstacleList::HMIObstacleList
struct HMIObstacleList
{
    Header header; // 消息头
    int32_t sensor_id; // 安装的传感器id(camera,lidar,radar) ' 相机id: 0-front_center相机 1-front_left相机 2-front_right相机 3-left_front相机 4-left_back右后相机 5-right_front相机 6-right_back相机 7-back相机'  8-相机融合
    int32_t obstacle_size;
    HMIObstacle obstacle[obstacle_size]; // 检测出的障碍物数组
    int32_t error_code; // 错误码（default = OK）
    boolean is_valid; // 障碍物数据是否合法
    int32_t change_origin_flag; // 坐标切换状态（0-坐标系切换成功 1-坐标系切换中 2-坐标系切换故障）
}

// HMITrajectoryPoint::HMITrajectoryPoint
struct HMITrajectoryPoint
{
    Point3D point; //  
    double v; //  
}

// HMITrajectory::HMITrajectory
struct HMITrajectory
{
    Header header; // 消息头
    int32_t trajectory_points_size;
    HMITrajectoryPoint trajectory_points[trajectory_points_size]; // 抽稀用来显示的轨迹点数组
}

// HMIDiagnosticStatus::HMIDiagnosticStatus
struct HMIDiagnosticStatus
{
    int32_t id; //  
    int32_t level; // // 诊断状态
    string name; // //测试/组件报告的描述
    string message; // // 状态描述
    string hardware_id; // // 硬件的唯一描述
}

// HMIDiagnosticArray::HMIDiagnosticArray
struct HMIDiagnosticArray
{
    Header header; // timestamp is  included in header
    int32_t status_size;
    HMIDiagnosticStatus status[status_size]; //  
}

// GuideInfo::GuideInfo
struct GuideInfo
{
    Header header; // 头部信息
    double next_dis; // 下一条规划路线上道路的距离
    GuideRoad current_road; // 当前道路的引导信息
    GuideRoad next_road; // 下一条规划道路的引导信息
    int8_t round_status; // 环岛状态: 0：未知或非环岛状态 1：当前为非环岛道路并且规划路线即将驶入环岛主路 2：当前道路类型是环岛并且规划路线还是在环岛主路中行驶 3：当前道路类型是环岛并且规划路线即将驶出环岛主路
    int8_t intersection_status; // 交叉路口状态: 0：未知 1：非交叉路口状态 2：交叉路口通行状态
    int8_t roads_status; // 当前行车推荐状态引导：(跨路口) 0：1km内（1km配置文件可配置）无需要左转、右转路口 1：需要左转路口（1km配置文件可配置） 2：需要右转路口  3：车道级规划失败
}

// GuideRoad::GuideRoad
struct GuideRoad
{
    int64_t road_id; // 道路的id
    int8_t road_type; // 道路的类型: 0：未知或一般道路  1：环岛 2：交叉路口 3：主路 4：辅路
    int8_t turn_type; // 规划路线上道路的转向信息 1：左转 2：直行 3：右转
    double avg_curvature; // 道路的平均曲率
    int32_t curvature_size; // 道路中心线上点(曲率)数量
    CurvatureInfo curvature[curvature_size]; // 道路曲率信息数组
}

// CurvatureInfo::CurvatureInfo
struct CurvatureInfo
{
    double offset; // 道路中心线上点位于该道路的位置（与道路起点的距离）
    double value; // 道路中心线上点的曲率值
}

