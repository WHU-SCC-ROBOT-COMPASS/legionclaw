package lcm_interface;

// LaneInfoExtend::LaneInfoExtend
struct LaneInfoExtend
{
    int8_t priority; // 道路优先级
    int64_t global_id; // 道路全局id（从左至右，从0开始）
    int32_t predecessor_ids_size;
    int64_t predecessor_ids[predecessor_ids_size]; // 所有的前继车道id数组
    int32_t successor_ids_size;
    int64_t successor_ids[successor_ids_size]; // 所有的后续车道id数组
    int64_t left_neighbor_id; // 左边相邻车道id
    int64_t right_neighbor_id; // 右边相邻车道id
    int8_t type; // 类型（预留）
    int32_t lane_points_size;
    LanePoint lane_points[lane_points_size]; // 道路参考线（z）
}

// LocalMap::LocalMap
struct LocalMap
{
    Header header; // timestamp is included in header
    int32_t seq; // Sequence number，lane_list数据有更新则加1，否则保持不变
    Point3D ego_point; // 生成该LocalMap局部地图消息时的自车位置
    double range; // 生成该LocalMap局部地图消息的范围，以ego_point为中心，range为边长的正方形，单位：m
    int32_t lane_list_size;
    LaneInfoExtend lane_list[lane_list_size]; // 自车周边LocalMap范围内的车道信息列表
}

// Common::Header
struct Header
{
    int32_t seq; // Sequence number for each message. Each module maintains its own counter for sequence_num, always starting from 1 on boot.
    Time stamp; // 时间戳
    string frame_id; // 帧id
}

// Common::Time
struct Time
{
    int32_t sec; // 秒
    int32_t nsec; // 纳秒
}

// Common::Status
struct Status
{
    int32_t error_code; // 错误码
    string msg; // 错误码描述
}

// Common::PointENU
struct PointENU
{
    double x; // East from the origin, in meters.
    double y; // North from the origin, in meters.
    double z; // Up from the WGS-84 ellipsoid, in meters.
}

// Common::PointBasic
struct PointBasic
{
    double x; // 位置坐标x
    double y; // 位置坐标y
    double z; // 位置坐标z
    double theta; // heading(rad)
}

// Common::PointLLH
struct PointLLH
{
    double lon; // Longitude in degrees, ranging from -180 to 180.
    double lat; // Latitude in degrees, ranging from -90 to 90.
    double height; // WGS-84 ellipsoid height in meters.
}

// Common::Point2D
struct Point2D
{
    double x; // 位置坐标x
    double y; // 位置坐标y
}

// Common::Point3D
struct Point3D
{
    double x; // 位置坐标x
    double y; // 位置坐标y
    double z; // 位置坐标z
}

// Common::Quaternion
struct Quaternion
{
    double qx; // 四维空间x
    double qy; // 四维空间y
    double qz; // 四维空间z
    double qw; // 四维空间w
}

// Common::Polygon3D
struct Polygon3D
{
    int32_t coordinate_system; // 坐标系
    int32_t points_size;
    Point3D points[points_size]; // 三维点集
}

// Common::Polygon2D
struct Polygon2D
{
    int32_t coordinate_system; // 坐标系
    int32_t points_size;
    Point2D points[points_size]; // 二维点集
}

// Common::ImageKeyPoint
struct ImageKeyPoint
{
    double x; // 车位图像关键点x坐标
    double y; // 车位图像关键点y坐标
    double confidence; // 置信度
}

// Common::SLPoint
struct SLPoint
{
    double s; // 纵向位移
    double l; // 横向位移
}

// Common::SLBoundary
struct SLBoundary
{
    double start_s; // 起始点纵向位移
    double end_s; // 终止点纵向位移
    double start_l; // 起始点横向位移
    double end_l; // 终止点横向位移
    int32_t boundary_point_size;
    SLPoint boundary_point[boundary_point_size]; // sl点集
}

// Common::FrenetFramePoint
struct FrenetFramePoint
{
    double s; // 纵向位移
    double l; // 横向位移
    double dl; // 横向位移变化率
    double ddl; // 横向位移变化率的变化率
}

// Common::SpeedPoint
struct SpeedPoint
{
    double s; // 里程
    double t; // 时间
    double v; // speed (m/s)
    double a; // acceleration (m/s^2)
    double da; // jerk (m/s^3)
}

// Common::PathPoint
struct PathPoint
{
    double x; // coordinates x
    double y; // coordinates y
    double z; // coordinates z
    double theta; // direction on the x-y plane
    double kappa; // curvature on the x-y planning
    double s; // accumulated distance from beginning of the path
    double dkappa; // derivative of kappa w.r.t s.
    double ddkappa; // derivative of derivative of kappa w.r.t s.
    double lane_id; // The lane ID where the path point is on
    double x_derivative; // derivative of x w.r.t parametric parameter t in CosThetareferenceline
    double y_derivative; // derivative of y w.r.t parametric parameter t in CosThetareferenceline
}

// Common::Path
struct Path
{
    string name; // 名称
    int32_t path_points_size;
    PathPoint path_points[path_points_size]; // 路径点集
}

// Common::TrajectoryPoint
struct TrajectoryPoint
{
    PathPoint path_point; // path point
    double v; // linear velocity
    double a; // linear acceleration
    double relative_time; // relative time from beginning of the trajectory
    double da; // longitudinal jerk
    boolean is_steer_valid; // 转向是否有效
    double front_steer; // The angle between vehicle front wheel and vehicle longitudinal axis
    double rear_steer; // 后轮转角
    int32_t gear; // 档位
}

// Common::Trajectory
struct Trajectory
{
    string name; // 轨迹名称
    int32_t trajectory_points_size;
    TrajectoryPoint trajectory_points[trajectory_points_size]; // 轨迹点
}

// Common::VehicleMotionPoint
struct VehicleMotionPoint
{
    TrajectoryPoint trajectory_point; // trajectory point
    double steer; // The angle between vehicle front wheel and vehicle longitudinal axis
}

// Common::VehicleMotion
struct VehicleMotion
{
    string name; // 名称
    int32_t vehicle_motion_point_size;
    VehicleMotionPoint vehicle_motion_point[vehicle_motion_point_size]; //  
}

// Common::GaussianInfo
struct GaussianInfo
{
    double sigma_x; // 标准差x
    double sigma_y; // 标准差y
    double correlation; // 相关性
    double area_probability; // Information of representative uncertainty area
    double ellipse_a; // 椭圆长轴
    double ellipse_b; // 椭圆短轴
    double theta_a; // 椭圆朝向
}

// Common::VehicleSignal
struct VehicleSignal
{
    int32_t turn_signal; // 转向信号
    boolean high_beam; // high beam
    boolean low_beam; // low beam
    boolean horn; // horn
    boolean emergency_light; // emergency light
}

// Common::PadMessage
struct PadMessage
{
    string cmd; // 命令
}

// Common::Stories
struct Stories
{
    string note; //  
}

// Common::Fault
struct Fault
{
    Time timestamp; // 时间戳
    int64_t code; // 故障码
    string reason; // 原因
}

// Common::Faults
struct Faults
{
    Header header; // 消息头
    int32_t version; // 版本号
    int32_t app_id; // 应用app所分配的id
    boolean is_active; // 应用是否激活，激活为true，未激活为false
    int32_t faults_size;
    Fault faults[faults_size]; // 故障集
}

// Common::Event
struct Event
{
    Time timestamp; // 时间戳
    int64_t code; // 0：invalid； 1：不可泊车；2：可以泊车；3：泊车完成； 4：不可泊出；5：可以泊出；6：泊出完成;   7 :  不可行车；8：可以行车；9：行车完成； 1X：退出自动驾驶（视退出场景可细分） 10：轨迹太短，请求退出自动驾驶; 20：拨杆换道驳回；21：执行向左拨杆换道;22：执行向右拨杆换道；23：拨杆换道完成 30：准备主动向左换道；31：执行主动向左换道；32：准备主动向右换道；33：执行主动向右换道；34：主动换道完成; 147: localmap的车道线效果不好，请求人工接管或者退出自动驾驶
    string reason; // 原因
}

// Common::Events
struct Events
{
    Header header; //  
    int32_t version; // 软件模块版本号
    int32_t events_size;
    Event events[events_size]; // 时间集
}

// Common::EStop
struct EStop
{
    boolean is_estop; // is_estop == true when emergency stop is required
    string reason; // 原因
}

// Common::Matrix3D
struct Matrix3D
{
    double a00; // 第一行第一列元素
    double a01; // 第一行第二列元素
    double a02; // 第一行第三列元素
    double a10; // 第二行第一列元素
    double a11; // 第二行第二列元素
    double a12; // 第二行第三列元素
    double a20; // 第三行第一列元素
    double a21; // 第三行第二列元素
    double a22; // 第三行第三列元素
}

// Common::Pose
struct Pose
{
    PointENU position; // Position of the vehicle reference point (VRP) in the map reference frame.   The VRP is the center of rear axle.
    Quaternion orientation; // A quaternion that represents the rotation from the IMU coordinate (Right/Forward/Up) to the world coordinate (East/North/Up).
    Point3D linear_velocity; // Linear velocity of the VRP in the map reference frame.East/north/up in meters per second.
    Point3D linear_acceleration; // Linear acceleration of the VRP in the map reference frame. East/north/up in meters per square second.
    Point3D angular_velocity; // Angular velocity of the vehicle in the map reference frame.Around east/north/up axes in radians per second.
    double heading; // The heading is zero when the car is facing East and positive when facing North
    Point3D linear_acceleration_vrf; // Linear acceleration of the VRP in the vehicle reference frame.Right/forward/up in meters per square second.
    Point3D angular_velocity_vrf; // Angular velocity of the VRP in the vehicle reference frame. Around right/forward/up axes in radians per second.
    Point3D euler_angles; // // Roll/pitch/yaw that represents a rotation with intrinsic sequence z-x-y.   // in world coordinate (East/North/Up)   // The roll, in (-pi/2, pi/2), corresponds to a rotation around the y-axis.   // The pitch, in [-pi, pi), corresponds to a rotation around the x-axis.   // The yaw, in [-pi, pi), corresponds to a rotation around the z-axis.   // The direction of rotation follows the right-hand rule.
}

// Common::Uncertainty
struct Uncertainty
{
    Point3D position_std_dev; // Standard deviation of position, east/north/up in meters.
    Point3D orientation_std_dev; // Standard deviation of quaternion qx/qy/qz, unitless.
    Point3D linear_velocity_std_dev; // Standard deviation of linear velocity, east/north/up in meters per second.
    Point3D linear_acceleration_std_dev; // Standard deviation of linear acceleration, right/forward/up in meters per square second.
    Point3D angular_velocity_std_dev; // Standard deviation of angular velocity, right/forward/up in radians per second.
}

// Chassis::Chassis
struct Chassis
{
    Header header; //  
    int32_t moving_status; // 移动状态
    int32_t driving_mode; // 驾驶状态
    int32_t steer_driving_mode; // 线控转向驾驶模式
    int32_t steering_status; // 线控转向执行器状态
    double front_steering_value; // 方向盘转角
    double rear_steering_value; // 后轮转角
    double steering_torque_nm; // 方向盘扭矩
    double front_steering_rate_dps; // 方向盘转速
    double rear_steering_rate_dps; // 方向盘转速
    int32_t accel_driving_mode; // 线控驱动驾驶模式
    int32_t accel_status; // 线控驱动状态
    double accel_value; // 线控驱动值（油门值）
    int32_t brake_driving_mode; // 线控制动驾驶模式
    int32_t brake_status; // 线控制动状态
    double brake_value; // 线控制动值（刹车值）
    int32_t backup_brake_driving_mode; // 备用线控制动驾驶模式
    int32_t backup_brake_status; // 备用线控制动状态
    double backup_brake_value; // 备用线控制动值
    int32_t epb_driving_mode; // EPB驾驶模式
    int32_t epb_status; // EPB状态
    int32_t epb_level; // EPB档位
    int32_t engine_status; // 发动机状态
    double engine_rpm; // 发动机转速
    double engine_torque; // 发动机扭矩
    double speed_mps; // 车速（m/s）
    double odometer_m; // 里程(m)
    int32_t fuel_range_m; // 油表值
    int32_t gear_driving_mode; // 档位驾驶模式
    int32_t gear_status; // 档位状态
    int32_t gear_location; // 档位值
    int32_t driver_seat_belt; // 主驾驶位安全带状态
    int32_t high_beam_status; // 远光灯状态
    int32_t low_beam_status; // 近光灯状态
    int32_t horn_status; // 喇叭状态
    int32_t turn_lamp_status; // 转向灯状态
    int32_t front_wiper_status; // 前雨刮器状态
    int32_t rear_wiper_status; // 后雨刮器状态
    int32_t position_lamp_status; // 位置灯状态
    int32_t front_fog_lamp_status; // 前雾灯状态
    int32_t rear_fog_lamp_status; // 后雾灯状态
    int32_t brake_lamp_status; // 刹车灯状态
    int32_t alarm_lamp_status; // 报警灯状态
    int32_t lf_door_status; // 左前门状态
    int32_t rf_door_status; // 右前门状态
    int32_t lr_door_status; // 左后门状态
    int32_t rr_door_status; // 右后门状态
    int32_t rearview_mirror_status; // 后视镜状态
    int32_t trunk_status; // 后备箱盖状态
    int32_t engine_bay_door_status; // 发送机舱盖状态
    int32_t wheel_direction_rr; // 右后轮方向
    double wheel_spd_rr; // 右后轮速
    int32_t wheel_direction_rl; // 左后轮方向
    double wheel_spd_rl; // 左后轮值
    int32_t wheel_direction_fr; // 右前轮方向
    double wheel_spd_fr; // 右前轮速
    int32_t wheel_direction_fl; // 左前轮方向
    double wheel_spd_fl; // 左前轮速
    int32_t is_tire_pressure_ok; // 胎压是否正常
    int32_t is_tire_pressure_lf_valid; // 左前轮胎压是否有效
    double tire_pressure_lf; // 左前轮胎压
    int32_t is_tire_pressure_rf_valid; // 右前轮胎压是否有效
    double tire_pressure_rf; // 右前轮胎压
    int32_t is_tire_pressure_lr_valid; // 左后轮胎压是否有效
    double tire_pressure_lr; // 左后轮胎压
    int32_t is_tire_pressure_rr_valid; // 右后轮胎压是否有效
    double tire_pressure_rr; // 右后轮胎压
    double battery_power_percentage; // 电池电量值
    int32_t air_bag_status; // 气囊状态
    int32_t charging_gun_status; // 充电枪状态
    int32_t vehicle_power_status; // 电量表状态
    int32_t chassis_error_code_size;
    int32_t chassis_error_code[chassis_error_code_size]; // 底盘错误码
}

// ControlCommand::ControlCommand
struct ControlCommand
{
    Header header; //  
    int32_t steer_driving_mode; // 0=COMPLETE_MANUAL  1=COMPLETE_AUTO_DRIVE 4=EMERGENCY_MODE
    double front_steering_target; // target steering angle
    double rear_steering_target; // target steering angle
    double front_steering_rate; // target non-directional steering rate
    double rear_steering_rate; // target non-directional steering rate
    int32_t accel_driving_mode; // 0=COMPLETE_MANUAL  1=COMPLETE_AUTO_DRIVE 4=EMERGENCY_MODE
    double accel_value; // target accel value
    int32_t brake_driving_mode; // 0=COMPLETE_MANUAL  1=COMPLETE_AUTO_DRIVE 4=EMERGENCY_MODE
    double brake_value; // target brake
    int32_t backup_brake_driving_mode; // 0=COMPLETE_MANUAL  1=COMPLETE_AUTO_DRIVE 4=EMERGENCY_MODE
    double backup_brake_value; // target brake
    int32_t epb_driving_mode; // 0=COMPLETE_MANUAL  1=COMPLETE_AUTO_DRIVE 4=EMERGENCY_MODE
    int32_t epb_level; // 0=RELEASE 1=APPLIY 2=INVALID
    int32_t gear_driving_mode; // 0=COMPLETE_MANUAL  1=COMPLETE_AUTO_DRIVE 4=EMERGENCY_MODE
    int8_t emergency_brake_enable; // 0=disenable  1=enable
    int32_t gear_location; // 0=GEAR_NEUTRAL 1=GEAR_DRIVE 2=GEAR_REVERSE 3=GEAR_PARKING 4=GEAR_LOW 5=GEAR_INVALID 6=GEAR_NONE
    double speed; // target speed, in m/s
    double acceleration; // target acceleration in m`s^-2
    int32_t turn_lamp_ctrl; // 转向灯 0 关闭 1 开启 2 不响应
    int32_t high_beam_ctrl; // 0 关闭 1 开启 2 不响应
    int32_t low_beam_ctrl; // 0 关闭 1 开启 2 不响应
    int32_t horn_ctrl; // 0 关闭 1 开启 2 不响应
    int32_t front_wiper_ctrl; // 前雨刮器 0 关闭 1 开启
    int32_t rear_wiper_ctrl; // 后雨刮器 0 关闭 1 开启
    int32_t position_lamp_ctrl; // 位置灯 0 关闭 1 开启
    int32_t front_fog_lamp_ctrl; // 前雾灯 0 关闭 1 开启
    int32_t rear_fog_lamp_ctrl; // 后雾灯 0 关闭 1 开启
    int32_t brake_lamp_ctrl; // 刹车灯 一般情况自动控制 0 关闭 1 开启
    int32_t alarm_lamp_ctrl; // 警报灯 双闪 0 关闭 1 开启
    int32_t lf_door_ctrl; // 左前门控制 0 关闭 1 开启
    int32_t rf_door_ctrl; // 右前门控制 0 关闭 1 开启
    int32_t lr_door_ctrl; // 左后门控制 0 关闭 1 开启
    int32_t rr_door_ctrl; // 右后门控制 0 关闭 1 开启
}

// WheelInfo::WheelInfo
struct WheelInfo
{
    Header header; //  
    int32_t moving_status; // 0=UNKNOWN_VEHICLE_STATE  1=STATIONARY  2=MOVING_FORWARD  3=MOVING_BACKWARD
    int32_t steer_driving_mode; // 0=COMPLETE_MANUAL  1=COMPLETE_AUTO_DRIVE  4=EMERGENCY_MODE
    double steering_value; // Real steering location
    double steering_torque_nm; // Applied steering torque in [Nm]
    double steering_rate_dps; // degree/s
    double speed_mps; // Vehicle Speed in meters per second
    boolean veh_spd_vld; // 车速有效性
    int32_t gear; // 档位
    boolean gear_vld; // 档位有效性
    int32_t wheel_direction_rr; // 0=FORWARD 1=BACKWARD 2=STANDSTILL 3=INVALID
    double wheel_spd_rr; // Actual speed of the right rear wheel
    int32_t wheel_direction_rl; // 0=FORWARD 1=BACKWARD 2=STANDSTILL 3=INVALID
    double wheel_spd_rl; // Actual speed of the left rear wheel
    int32_t wheel_direction_fr; // 0=FORWARD 1=BACKWARD 2=STANDSTILL 3=INVALID
    double wheel_spd_fr; // Actual speed of the right front wheel
    int32_t wheel_direction_fl; // 0=FORWARD 1=BACKWARD 2=STANDSTILL 3=INVALID
    double wheel_spd_fl; // Actual speed of the left front wheel
    double yaw_rate; // Yaw rate[degree/s] [-163.84|163.835]
    int32_t wss_fl_edges_sum; // 左前轮边缘和
    int32_t wss_fr_edges_sum; // 右前轮边缘和
    int32_t wss_rl_edges_sum; // 左后轮边缘和
    int32_t wss_rr_edges_sum; // 右后轮边缘和
    boolean wss_fl_edges_sum_vld; // 左前轮边缘和有效位（0：无效 1：有效）
    boolean wss_fr_edges_sum_vld; // 右前轮边缘和有效位（0：无效 1：有效）
    boolean wss_rl_edges_sum_vld; // 左后轮边缘和有效位（0：无效 1：有效）
    boolean wss_rr_edges_sum_vld; // 右后轮边缘和有效位（0：无效 1：有效）
    double veh_lat_accel; // 车辆横向加速度
    double veh_lgt_accel; // 车辆纵向加速度
    boolean veh_lat_accel_vld; // 车辆横向加速度有效性
    boolean veh_lgt_accel_vld; // 车辆纵向加速度有效性
}

// ControlAnalysis::ControlAnalysis
struct ControlAnalysis
{
    Header header; //  
    int32_t driving_mode; // 驾驶模式
    int32_t driving_mode_fd; // 驾驶模式反馈
    int32_t gear_location_fd; // 档位反馈
    int32_t gear_location_cmd; // 档位命令
    int32_t epb_level_fd; // EPB状态反馈
    int32_t epb_level_cmd; // EPB命令
    double speed_mps; // 车辆速度
    double speed_reference; // 参考速度
    double accel_value_fd; // 油门反馈
    double accel_value_cmd; // 油门命令
    double brake_value_fd; // 刹车反馈
    double brake_value_cmd; // 刹车命令
    double path_remain; // 剩余轨迹里程
    boolean has_stop_point; // 是否有停车点
    boolean is_full_stop; // 是否有停车轨迹
    boolean is_stopped; // 是否停车
    double lon_acc_jerk; // 纵向加加速度
    double acceleration_cmd; // 加速度命令
    double acceleration_cmd_closeloop; // 闭环加速度命令
    double preview_acceleration_reference; // 预描参考加速度
    double slope_offset_compensation; // 坡道补偿
    double turning_offset_compensation; // 转向补偿
    double speed_error_limited; // 速度差限值
    double speed_error; // 速度差
    double speed_offset; //  
    double station_error_limited; // 位置误差限值
    double station_error; // 位置误差
    double lon_target_point_s; // 纵向控制目标点里程
    int64_t lon_calculate_time; // 纵向计算时间
    int64_t lon_calculate_time_max; // 纵向时间限值
    double ref_curvature; // 参考曲率
    double ref_heading; // 参考航向角
    double current_heading; // 当前航向角
    double heading_error; // 航向角误差
    double heading_error_rate; // 航向角误差率
    double lateral_error; // 横向误差
    double lateral_error_rate; // 横向误差率
    double lon_error; // 纵向误差
    double front_steering_value_fd; // 前轮转向反馈
    double front_steering_target; // 前轮目标转向
    double front_steering_rate; // 前轮转向角速率
    double front_steer_angle_feedforward; // 前轮前馈计算
    double front_steer_angle_feedback; // 前轮反馈计算
    double front_steer_angle_lateral_contribution; // 前轮横向误差贡献
    double front_steer_angle_lateral_rate_contribution; // 前轮横向误差率贡献
    double front_steer_angle_heading_contribution; // 前轮航向角误差贡献
    double front_steer_angle_heading_rate_contribution; // 前轮航向角误差率贡献
    double rear_steering_value_fd; // 后轮转向反馈
    double rear_steering_target; // 后轮目标转向
    double rear_steering_rate; // 后轮转向角速率
    double rear_steer_angle_feedforward; // 后轮前馈计算
    double rear_steer_angle_feedback; // 后轮反馈计算
    double rear_steer_angle_lateral_contribution; // 后轮横向误差贡献
    double rear_steer_angle_lateral_rate_contribution; // 后轮横向误差率贡献
    double rear_steer_angle_heading_contribution; // 后轮航向角误差贡献
    double rear_steer_angle_heading_rate_contribution; // 后轮航向角误差率贡献
    double matrix_k_00; // k矩阵
    double matrix_k_01; // k矩阵
    double matrix_k_02; // k矩阵
    double matrix_k_03; // k矩阵
    double matrix_k_10; // k矩阵
    double matrix_k_11; // k矩阵
    double matrix_k_12; // k矩阵
    double matrix_k_13; // k矩阵
    double matrix_state_0; // 状态矩阵
    double matrix_state_1; // 状态矩阵
    double matrix_state_2; // 状态矩阵
    double matrix_state_3; // 状态矩阵
    double matrix_q_updated_0; // 权重矩阵
    double matrix_q_updated_1; // 权重矩阵
    double matrix_q_updated_2; // 权重矩阵
    double matrix_q_updated_3; // 权重矩阵
    double current_x; // 当前位置x
    double current_y; // 当前位置y
    double target_point_x; // 目标点x
    double target_point_y; // 目标点y
    double lat_target_point_s; // 横向目标点里程
    int64_t lqr_calculate_time; // LQR计算时间
    int64_t lqr_calculate_time_max; // LQR计算时间限值
}

// VehicleParam::VehicleParam
