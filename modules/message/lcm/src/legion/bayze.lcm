    double lat_error; // 横向误差
    double lon_error; // 纵向误差
    double yaw_error; // 角度误差(度)
    int32_t obstacles_vec_size;
    Point2dList obstacles_vec[obstacles_vec_size]; //  
    int32_t warm_start_traj_size;
    TrajectoryPoint warm_start_traj[warm_start_traj_size]; //  
