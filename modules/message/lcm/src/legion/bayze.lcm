    int32_t grid_map_size;
    Grid grid_map[grid_map_size]; // 栅格地图
}

// Region::Region
struct Region
{
    int32_t name_region; // 前后左右区域
    double score; // 车辆前后左右的区域打分获得的分值(0-100表示逐步危险程度)
    int32_t rank_risk; // 危险程度(0-3四级划分，不同分级对应不同驾驶处理策略)
    int32_t region_polygon_size;
    Point3D region_polygon[region_polygon_size]; // 世界坐标系下的区域多边形
}

// Grid::Grid
struct Grid
{
    double x; // 世界坐标系下的x
    double y; // 世界坐标系下的y
    SLPoint sl_point; // Frenet坐标系下的x
    double yaw; //  
    double potential; // 势场值
    int32_t region_id; // 区域编号
}

// CameraParkingInfo::CameraParkingInfo
struct CameraParkingInfo
{
    Header header; // timestamp is  included in header
    int32_t parking_space_id; // 停车位id
    int32_t parking_type; // PARKING_TYPE=0//无效泊车 PARKING_TYPE=1//垂直泊车 PARKING_TYPE=2//水平泊车 PARKING_TYPE=3//倾斜泊车
    boolean is_parking_enable; // PARKING_ENABLE=0//不可泊入 PARKING_ENABLE=1//可泊入
    double confidence; // 停车位置信度
    Point3D center_point_of_parking; // 车辆坐标系的停车位中心点
    double theta; // 车辆坐标系下停车位的朝向
    double width; // 停车位宽
    double length; // 停车位长
    double yaw_offset; // 停车位角度偏移量（倾斜车位），倾斜车位与道路边线夹角
    int32_t parking_points_in_image_size;
    ImageKeyPoint parking_points_in_image[parking_points_in_image_size]; // 图像坐标系下停车位关键点，顺时针方向
}

// CameraParkingInfoList::CameraParkingInfoList
struct CameraParkingInfoList
{
    Header header; // 消息头，时间戳使用接收的图像的时间戳
    int32_t sensor_id; // 安装的传感器id(camera,lidar,radar) ' 相机id: 0-front_center相机 1-front_left相机 2-front_right相机 3-left_front相机 4-left_back右后相机 5-right_front相机 6-right_back相机 7-back相机'  8-相机融合
    int32_t camera_parking_size;
    CameraParkingInfo camera_parking[camera_parking_size]; // 检测出的障碍物数组
    int32_t camera_parking_stoppers_size;
    CameraParkingStopper camera_parking_stoppers[camera_parking_stoppers_size]; // 检测出的限位器数组
    int32_t error_code; // 错误码（default = OK）
    boolean is_valid; // 障碍物数据是否合法
}

