    boolean kappa_limit_enable; //  
    double kappa_limit; // deg/m
}

// ParkingInfoList::ParkingInfoList
struct ParkingInfoList
{
    Header header; // 消息头
    int32_t parking_info_size;
    ParkingInfo parking_info[parking_info_size]; // 检测出的停车位数组
    int32_t error_code; // 错误码（default = OK）
    boolean is_valid; // 车位数据是否合法
    boolean parking_out_enable; // 是否能泊出
    int32_t parking_out_direction; // 泊出方向
    int32_t parking_out_id; // 当前自车所在车位ID
}

// CommCommand::CommCommand
struct CommCommand
{
    Header header; //  
    string name; // 发送指令的节点名称
    int8_t self_id; // 发送节点的ID号，参考apps描述
    int32_t commands_size;
    Command commands[commands_size]; // 需要发送的指令，如果需要发送给多个节点，需要使用多个command
}

// CommandRespond::CommandRespond
struct CommandRespond
{
    Header header; //  
    string name; // 发送指令的节点名称
    int8_t self_id; // 发送节点的ID号，参考apps描述
    int8_t respond_id; //  
    int8_t status; // 0 无响应 1 响应失败 2 响应成功
    int32_t fail_code; // 失败原因
}

// ModuleStatus::ModuleStatus
struct ModuleStatus
{
    Header header; //  
    string name; // 发送指令的节点名称
    int8_t self_id; // 发送节点的ID号，参考apps描述
    int32_t status; //  枚举方式 sef_id+status,比如设置1为开，2为关，当前sef_id是21，则在关闭状态下反馈值是 212
    int32_t messages_size;
    Message messages[messages_size]; // 需要输出的消息列表：eg:要求显示剩余里程数为100米，self_id 为21，里程数id为08，code值为2108，value值为10000，精度为cm
}

// Command::Command
struct Command
{
    string target_module; // 目标节点名称
    int8_t target_id; // 目标节点ID
    int32_t target_switch; // 0:保持target_module的状态  1:打开target_module 2:关闭target_module
}

// Message::Message
struct Message
{
    int32_t code; // 指定需要显示的值的code定义，需要与self_id绑定 作为前缀
    int32_t value; // 对应显示的值或表达的状态
}

// PlanningAnalysis::PlanningAnalysis
struct PlanningAnalysis
{
    Header header; //  
    double frame_update_time; // frame update计算时间
    double generator_time; // 轨迹生成 计算时间
    int32_t evaluator_time_size;
    TimeConsume evaluator_time[evaluator_time_size]; // 轨迹评估计算时间
    double selector_time; // 轨迹选择计算时间
    PlanningParkingDebug planning_parking_debug; // planning泊车调试消息
    double dis_to_center_line; // 车辆距离车道中心线的垂直距离
    double diff_to_velocity; // 目标速度与规划速度之差
    double referencline_kappa; // 参考线曲率
}

// TimeConsume::TimeConsume
struct TimeConsume
{
    string name; //  
    double time_consume; //  
}

