    double back_edge_to_center; //  
    double lf; //  
    double lr; //  
    double cf; //  
    double cr; //  
    double steer_ratio; //  
    double rolling_coefficient; //  
    double air_density; //  
    double air_damping_coefficient; //  
    double max_front_steer_angle; //  
    double min_front_steer_angle; //  
    double max_rear_steer_angle; //  
    double min_rear_steer_angle; //  
