struct VehicleConfig
{
    Header header; //  
    VehicleParam vehicle_param; // 车辆参数表
}

// PredictionObstacles::PredictionObstacles
struct PredictionObstacles
{
    Header header; // timestamp is included in header
    int32_t prediction_obstacles_size;
    PredictionObstacle prediction_obstacles[prediction_obstacles_size]; // make prediction for multiple obstacles
    int32_t change_origin_flag; // 0:坐标系切换成功 1:坐标系切换中 2:坐标系切换故障
    double start_timestamp; // start timestamp
    double end_timestamp; // end timestamp
    int32_t self_intent; // 自动驾驶车辆意图  0-UNKNOWN, 1-STOP, 2-CRUISE, 3-CHANGE_LANE
    int32_t scenario; // 场景              0-UNKNOWN, 1000-CRUISE, 1001-CRUISE_URBAN 1002-CRUISE_HIGHWAY, 2000-JUNCTION  2001-JUNCTION_TRAFFIC_LIGHT 2002-JUNCTION_STOP_SIGN
}

// Location::Location
struct Location
{
    Header header; // 消息头
    PointLLH position; // 经纬度高程
    double pitch; // 方向(单位弧度，-π～π,正东:0, 逆时针。都满足右手定则)
    double roll; //  
    double heading; //  
    Point3D linear_velocity; // 线速度（m/s，北东地坐标系）
    Point3D linear_acceleration; // 线加速度（m/s2，前右下坐标系）
    Point3D angular_velocity; // 角速度（度/s，前右下，满足右手定则）
    int32_t rtk_flag; // RTK标志值
    int32_t odom_type; // 融合标志:0-(纯ins) 1-(纯轮速) 2-(泊车递推) 3-(无) 4-(orb匹配定位)
    int32_t auxiliary_type; // 辅助方式:0-NULL(无辅助方式) 1-laneliine_map(车道线/标识牌)2-feature_map(lidar)3-feature_map(lidar_camera)
    int32_t location_valid_flag; // Location有效性标志位0: invalid； 1: valid
    double origin_lat; // 参考点纬度 GCJ-02格式
    double origin_lon; // 参考点经度 GCJ-02格式
    PointENU utm_position; // 相对参考点xyz坐标
    int32_t change_origin_flag; // 0::无坐标系切换 1:坐标系切换成功2:坐标系切换中3:坐标系切换故障
    PointENU utm_position_next; // 相对参考点坐标(切换状态下，为新的原点坐标系下)
    Point3D position_std_dev; // 位置标准差
    Point3D orientation_std_dev; // 方向标准差
    Point3D linear_velocity_std_dev; // 速度标准差
    Point3D linear_acceleration_std_dev; // 加速度标准差
    Point3D angular_velocity_std_dev; // 角速度标准差
}

// Odometry::Odometry
struct Odometry
{
    Header header; // 含有时间戳信息的结构体
    PointENU position; // 位置
    Quaternion orientation; // 角度
    int32_t covariance_size;
    double covariance[covariance_size]; // 方差
}

// ObstacleList::ObstacleList
struct ObstacleList
{
    Header header; // 消息头
    int32_t sensor_id; // 安装的传感器id(camera,lidar,radar) ' 相机id: 0-front_center相机 1-front_left相机 2-front_right相机 3-left_front相机 4-left_back右后相机 5-right_front相机 6-right_back相机 7-back相机'  8-相机融合
    int32_t obstacle_size;
    Obstacle obstacle[obstacle_size]; // 检测出的障碍物数组
    int32_t error_code; // 错误码（default = OK）
    boolean is_valid; // 障碍物数据是否合法
    int32_t change_origin_flag; // 坐标切换状态（0-坐标系切换成功 1-坐标系切换中 2-坐标系切换故障）
}

// LaneList::LaneList
struct LaneList
{
    Header header; // 消息头
    int32_t sensor_id; // 安装的传感器id(camera,lidar,radar) ' 相机id: 0-front_center相机 1-front_left相机 2-front_right相机 3-left_front相机 4-left_back右后相机 5-right_front相机 6-right_back相机 7-back相机'  8-相机融合
    int8_t error_code; // 错误码： ERROR_NONE = 0; ERROR_UNKNOWN = 1;
    int8_t sensor_status; // 传感器状态： NORMAL=0； ABNORMAL=1；
    int32_t change_origin_flag; // 坐标切换状态（0-坐标系切换成功 1-坐标系切换中 2-坐标系切换故障）
    boolean is_valid; // 车道线数据是否合法
    SensorCalibrator sensor_calibrator; // 传感器标定参数
    int32_t camera_laneline_size;
    LaneLine camera_laneline[camera_laneline_size]; // 车道线检测结果数组
    HolisticPathPrediction hpp; // 行驶预测线
    int32_t road_marks_size;
    RoadMark road_marks[road_marks_size]; // 路面标识
}

// TrafficLightMsg::TrafficLightMsg
struct TrafficLightMsg
{
    Header header; // 消息头
    int32_t traffic_light_size;
    TrafficLight traffic_light[traffic_light_size]; // 检出的交通灯数组
    TrafficLightDebug traffic_light_debug; // 交通灯数组调试
    boolean contain_lights; // 是否包含交通灯
    int32_t camera_id; // CAMERA_FRONT_LONG = 0; CAMERA_FRONT_NARROW = 1; CAMERA_FRONT_SHORT = 2; CAMERA_FRONT_WIDE = 3;
    boolean is_valid; // true: valid  false: invalid
}

// Ultrasonic::Ultrasonic
struct Ultrasonic
{
    Header header; // 消息头
    int32_t ranges_size;
    UltrasonicObstacle ranges[ranges_size]; // 超声波障碍物数组
}

// RadarObstacleListMsg::RadarObstacleListMsg
struct RadarObstacleListMsg
{
    Header header; // 消息头
    int32_t radar_obstacle_size;
    RadarObstacle radar_obstacle[radar_obstacle_size]; // 毫米波雷达障碍物数组
    int8_t sensor_id; // 毫米波雷达 ID.
    RadarState radar_state; // radar state.
    boolean is_valid; // true: valid  false: invalid
}

// PointCloud::PointCloud
struct PointCloud
{
    Header header; // 消息头
    string frame_id; // 帧id
    boolean is_dense; // True if there are no invalid points
    int32_t point_size;
    PointXYZIRT point[point_size]; // 激光点结构体
    double measurement_time; // 测量时间
    int32_t width; // 激光点宽度
    int32_t height; // 激光点高度
}

// RadarObstacle::RadarObstacle
struct RadarObstacle
{
    int32_t id; // obstacle ID.
    int8_t life_time; // 障碍物存在时间
    Point2D relative_position; // 雷达坐标系障碍物位置
    Point2D relative_position_rms; // 雷达坐标系障碍物位置标准差
    Point2D relative_velocity; // 雷达坐标系障碍物速度
    Point2D relative_velocity_rms; // 雷达坐标系障碍物速度标准差
    Point2D relative_acceleration; // 雷达坐标系障碍物加速度
    Point2D relative_acceleration_rms; // 雷达坐标系障碍物加速度标准差
    double rcs; // 雷达散射面积
    double snr; //  
    int32_t moving_status; // STATIONARY = 0; NEARING = 1; AWAYING = 2; NONE = 3;
    double width; // 雷达障碍物宽度
    double length; // 雷达障碍物长度
    double height; // 雷达障碍物高度
    double theta; //  
    Point2D absolute_position; // obstacle position in map coordinate system
    Point2D absolute_position_rms; //  
    Point2D absolute_velocity; // obstacle position in map coordinate system
    Point2D absolute_velocity_rms; //  
    Point2D absolute_acceleration; //  
    Point2D absolute_acceleration_rms; //  
    double orientation; // 雷达障碍物方位角
    double orient_rms; // 雷达障碍物方位角标准差
    double yaw; //  
    double yaw_rms; //  
    int32_t count; //  
    int32_t moving_frames_count; //  
    Status status; // 状态码
    double underpass_probability; //  
    double overpass_probability; //  
    int8_t exist_probability; // 障碍物存在的概率
    int8_t mov_property; // 障碍物移动属性：MOVING_PROPERTY_MOVING=0，MOVING_PROPERTY_STATIONARY=1，MOVING_PROPERTY_ONCOMING=2，MOVING_PROPERTY_STATIONARY_CANDIDATE=3，MOVING_PROPERTY_UNKOWN=4，MOVING_PROPERTY_CROSSING_STATIONARY=5，MOVING_PROPERTY_CROSSING_MOVING=6，MOVING_PROPERTY_STOPPED=7
    int8_t track_state; // 跟踪状态：TRACK_STATE_DELETED=0；TRACK_STATE_INITED=1；TRACK_STATE_MEASURED=2；TRACK_STATE_PREDICTED=3；TRACK_STATE_DELETED_FOR_MERGE=4；TRACK_STATE_NEW_FOR_MERGE=5；
    int8_t track_type; // 追踪的障碍物类型：TRACK_TYPE_POINT=0；TRACK_TYPE_CAR=1；TRACK_TYPE_TRUCK=2；TRACK_TYPE_PEDESTRIAN=3；TRACK_TYPE_MOTORCYCLE=4；TRACK_TYPE_BICYCLE=5；TRACK_TYPE_WIDE=6；TRACK_TYPE_RESERVED=7；TRACK_TYPE_BRIDGE=8；
}

// UltrasonicObstacle::UltrasonicObstacle
struct UltrasonicObstacle
{
    int32_t id; // 障碍物id
    double range; // 障碍物距离
}

// PointXYZIRT::PointXYZIRT
struct PointXYZIRT
{
    double x; // x//坐标x
    double y; // y//坐标y
    double z; // z//坐标z
    int32_t intensity; // 反射强度
    int8_t ring_id; // 线束ID
    int64_t timestamp; // 时间戳
}

// CompressedImage::CompressedImage
struct CompressedImage
{
    Header header; // 消息头
    string frame_id; // 图像帧id
    string format; //  Specifies the format of the data Acceptable values: jpeg, png
    int32_t data_size;
    int8_t data[data_size]; // Compressed image buffer
    double measurement_time; // 测量时间
    int32_t frame_type; // 图像帧类型
}

// Image::Image
struct Image
{
    Header header; // 消息头
    int32_t height; // image height, that is, number of rows
    int32_t width; // image width, that is, number of columns
    string encoding; // 图像编码方式
    int8_t is_bigendian; // is this data bigendian?
    int32_t step; // Full row length in bytes
    int32_t data_size;
    int8_t data[data_size]; // actual matrix data, size is (step * rows)
}

// Gnss::Gnss
struct Gnss
{
    boolean is_valid; // 数据有效性标志位
    Header header; // 头部信息
    double latitude; // 纬度信息
    double longitude; // 经度信息
    double elevation; // 海拔信息
    Point3D utm_position; // UTM坐标位置
    int32_t utm_zone_num; // UTM区号
    int8_t utm_zone_char; // UTM区号
    Point3D attitude; // 三轴姿态
    Point3D sd_position; // 位置标准差
    Point3D sd_velocity; // 速度标准差
    Point3D sd_attitude; // 姿态标准差
    double second; // 时间
    int32_t sat_use_num; // 使用卫星数
    int32_t sat_in_view_num; // 可见卫星数
    int16_t solution_status; // 求解状态
    int16_t position_type; // 定位状态
    Point3D linear_velocity; // 线速度信息
    Point3D attitude_dual; // 双天线姿态
    Point3D sd_angle_dual; // 双天线角度标准差
    double base_line_length_dual; // 双天线距离
    int32_t solution_status_dual; // 双天线求解状态
    int32_t position_type_dual; // 双天线定位状态
    int32_t solution_source_dual; // 双天线求解源
    double cep68; // cep68数据位
    double cep95; // cep95数据位
    double p_dop; // pDop数据位
    double h_dop; // hDop数据位
    double v_dop; // vDop数据位
}

// Imu::Imu
struct Imu
{
    Header header; // 头部信息
    boolean is_valid; // 数据有效性标志位
    Quaternion orientation; // 角度（四元素）
    int32_t orientation_covariance_size;
    double orientation_covariance[orientation_covariance_size]; // 角度方差
    Point3D angular_velocity; // 角速度信息angularVelocity.x：x方向角速度信息angularVelocity.y: y方向角速度信息angularVelocity.z：z方向角速度信息
    int32_t angular_velocity_covariance_size;
    double angular_velocity_covariance[angular_velocity_covariance_size]; // 速度方差
    Point3D linear_acceleration; // 线加速度信息linearAcceleration.x：x方向线加速度信息linearAcceleration.y: y方向线加速度信息linearAcceleration.z：z方向线加速度信息
    int32_t linear_acceleration_covariance_size;
    double linear_acceleration_covariance[linear_acceleration_covariance_size]; // 线性加速度方差
}

// Ins::Ins
struct Ins
{
    Header header; // 头部信息
    boolean is_valid; // 数据有效性标志位
